--- !u!1001 &1787965664
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 69651678}
    m_Modifications:
    - target: {fileID: 101430908177647545, guid: 6c23efcffc48d4b458126a9f87bf2a74, type: 3}
      propertyPath: m_text
      value: "\u0414\u043B\u044F \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B
        \u043F\u0440\u043E\u0439\u0442\u0438 \u0443\u0440\u043E\u0432\u0435\u043D\u044C
        - \u043D\u0443\u0436\u043D\u043E \u043F\u0440\u043E\u0439\u0442\u0438 \u0447\u0435\u0440\u0435\u0437
        \u0434\u0432\u0435\u0440\u044C, \u0434\u0432\u0435\u0440\u044C \u0434\u043B\u044F
        \u0444\u0438\u043D\u0438\u0448\u0430 \u043F\u043E\u0434\u0441\u0432\u0435\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
        \u043E\u0440\u0430\u043D\u0436\u0435\u0432\u044B\u043C \u0446\u0432\u0435\u0442\u043E\u043C.
        \u0423 \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u0430
        \u0435\u0441\u0442\u044C \u043F\u043B\u0430\u0442\u0444\u043E\u0440\u043C\u0430,
        \u0432 \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043D\u0443\u0436\u043D\u043E
        \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C \u043B\u0430\u043C\u043F\u043E\u0447\u043A\u0443.
        \u041A\u0430\u0436\u0434\u0430\u044F \u043B\u0430\u043C\u043F\u043E\u0447\u043A\u0430
        \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u043D\u043D\u043E\u0433\u043E
        \u0446\u0432\u0435\u0442\u0430 \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D\u0430
        \u043A \u043A\u043D\u043E\u043F\u043A\u0435 \u0442\u0430\u043A\u043E\u0433\u043E
        \u0436\u0435 \u0446\u0432\u0435\u0442\u0430. \u041A\u043E\u0433\u0434\u0430
        \u0432\u044B \u0443\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0442\u0435
        \u043B\u0430\u043C\u043F\u043E\u0447\u043A\u0443 \u0432 \u0441\u043B\u043E\u0442,
        \u0442\u043E \u043F\u0440\u0438 \u043D\u0430\u0436\u0430\u0442\u0438\u0438
        \u043D\u0430 \u043A\u043D\u043E\u043F\u043A\u0443 \u0430\u043A\u0442\u0438\u0432\u0438\u0440\u0443\u0435\u0442\u0441\u044F
        \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C \u0443 \u0442\u043E\u0433\u043E
        \u043E\u0431\u044A\u0435\u043A\u0442\u0430, \u0443 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
        \u0435\u0441\u0442\u044C \u043B\u0430\u043C\u043F\u043E\u0447\u043A\u0430."
      objectReference: {fileID: 0}
